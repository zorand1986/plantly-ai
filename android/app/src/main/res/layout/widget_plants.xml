<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <!-- Header: tap opens the app -->
    <TextView
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💧 Water Today"
        android:textColor="#111111"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:paddingStart="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="6dp" />

    <!-- Divider (View is not allowed in RemoteViews on API 31+, use LinearLayout) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E8E8E8"
        android:layout_marginBottom="4dp"
        android:orientation="horizontal" />

    <!-- Plant list -->
    <ListView
        android:id="@+id/widget_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp" />

    <!-- Shown when no plants are due today -->
    <TextView
        android:id="@+id/widget_empty_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="All plants are happy 🌿"
        android:textColor="#999999"
        android:textSize="13sp" />

</LinearLayout>
